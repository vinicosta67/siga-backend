generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  password       String
  pfType         PfType          @default(FISICA)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  pessoaFisica   PessoaFisica?
  pessoaJuridica PessoaJuridica?

  permissions    Permission[]    @relation("users_permissions")

  @@map("users")
}

model Permission {
  id          Int      @id // Usaremos ID número fixo (1001, 1002) conforme pedido
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]   @relation("users_permissions")

  @@map("permissions")
}

enum MaritalStatus {
  SOLTEIRO
  CASADO
  DIVORCIADO
  VIUVO
  UNIAO_ESTAVEL
}

enum CompanySize {
  MEI
  ME
  EPP
  MEDIO
  GRANDE
}

enum PfType {
  FISICA
  JURIDICA
}

model PessoaFisica {
  id            String         @id @default(uuid())
  cpf           String         @unique
  rg            String?
  birthDate     DateTime?      @db.Date
  maritalStatus MaritalStatus?
  motherName    String?
  monthlyIncome Decimal?       @db.Decimal(10, 2)
  occupation    String?
  address       String?
  neighborhood  String?
  city          String
  state         String         @db.Char(2)
  zipCode       String

  userId        String         @unique
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("pessoa_fisica")
}

model PessoaJuridica {
  id             String       @id @default(uuid())
  cnpj           String       @unique
  companyName    String?
  tradeName      String?
  industry       String?      
  companySize    CompanySize?
  annualRevenue  Decimal?     @db.Decimal(15, 2)
  foundedDate    DateTime?    @db.Date
  machineryCount Int?
  employeeCount  Int?
  address        String?
  neighborhood   String?
  city           String
  state          String       @db.Char(2)
  zipCode        String

  userId         String       @unique
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("pessoa_juridica")
}
