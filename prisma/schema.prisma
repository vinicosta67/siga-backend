generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  pfType    PfType   @default(FISICA)
  emailVerified          Boolean   @default(false)
  emailVerificationToken String?
  emailTokenExpiry       DateTime?
  resetPasswordToken     String?
  resetPasswordExpiry    DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  pessoaFisica   PessoaFisica?
  pessoaJuridica PessoaJuridica?

  permissions Permission[] @relation("users_permissions")
  proposals   Proposal[]
  visits      Visit[]
  timelineEvents TimelineEvent[]

  @@map("users")
}

model Permission {
  id          Int      @id // Usaremos ID número fixo (1001, 1002) conforme pedido
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]   @relation("users_permissions")

  @@map("permissions")
}

enum MaritalStatus {
  SOLTEIRO
  CASADO
  DIVORCIADO
  VIUVO
  UNIAO_ESTAVEL
}

enum CompanySize {
  MEI
  ME
  EPP
  MEDIO
  GRANDE
}

enum PfType {
  FISICA
  JURIDICA
}

model PessoaFisica {
  id            String         @id @default(uuid())
  cpf           String         @unique
  rg            String?
  birthDate     DateTime      @db.Date
  maritalStatus MaritalStatus?
  motherName    String?
  monthlyIncome Decimal?       @db.Decimal(10, 2)
  occupation    String?
  address       String?
  neighborhood  String?
  city          String?
  state         String?         @db.Char(2)
  zipCode       String?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rgIssuer      String?
  nationality   String?
  gender        String?
  phone         String?
  addressNumber String?
  latitude      Float?
  longitude     Float?

  @@map("pessoa_fisica")
}

model PessoaJuridica {
  id             String       @id @default(uuid())
  cnpj           String       @unique
  companyName    String?
  tradeName      String?
  industry       String?
  companySize    CompanySize?
  annualRevenue  Decimal?     @db.Decimal(15, 2)
  foundedDate    DateTime?    @db.Date
  machineryCount Int?
  employeeCount  Int?
  address        String?
  neighborhood   String?
  city           String
  state          String       @db.Char(2)
  zipCode        String

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  stateRegistration String?
  cpf           String?
  rg            String?
  rgIssuer      String?
  birthDate     DateTime?    @db.Date
  nationality   String?
  gender        String?
  phone         String?
  addressNumber String?
  latitude      Float?
  longitude     Float?
  mainPartnerName String?
  fullName        String?


  @@map("pessoa_juridica")
}

model Proposal {
  id     String @id @default(uuid())
  title  String
  type   String
  status String @default("PENDENTE")

  // Detalhes do Projeto de Crédito
  sector         String?
  creditType     String?
  requestedValue Decimal?  @db.Decimal(15, 2)
  financedValue  Decimal? @db.Decimal(15, 2)
  monthlyIncome Decimal?  @db.Decimal(15, 2)
  term           Int
  gracePeriod    String?
  purpose        String?
  department     String? @default("CECAD")

  // Detalhes Complementares da Empresa no momento da Proposta
  companyName  String?
  industry     String?
  size         String?
  machinery    String?
  revenue      String? // Storing as string to match frontend mock or keep it loose, or change to Decimal
  email        String?
  phone        String?
  zip          String?
  state        String?
  city         String?
  neighborhood String?
  address      String?

  latitude     Float?
  longitude    Float?
  addressType  String?
  boundingBox  Json?
  addressInfo  Json?

  interestRate   String?
  amortization   String?
  totalArea      Float?
  productiveArea Float?

  userId     String
  user       User        @relation(fields: [userId], references: [id])
  documents  Document[]
  guarantees Guarantee[]
  timelineEvents TimelineEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("proposals")
}

model Document {
  id           String  @id @default(uuid())
  type         String
  url          String
  originalName String
  description  String?
  status       String  @default("AGUARDANDO_VALIDACAO")

  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@map("documents")
}

model Guarantee {
  id             String   @id @default(uuid())
  type           String
  description    String
  estimatedValue Decimal? @db.Decimal(15, 2)

  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@map("guarantees")
}

model Visit {
  id           String   @id @default(uuid())
  clientName   String
  scheduledAt  DateTime
  address      String
  status       String   @default("AGENDADA")
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  zip          String? // CEP
  street       String? // Rua
  number       String? // Número
  neighborhood String? // Bairro
  city         String? // Cidade
  state        String? // Estado (UF)
  complement   String? // Complemento

  // Geolocation para o MAPA
  latitude  Float?
  longitude Float?

  opportunities String[] // Novas oportunidades identificadas

  @@map("visits")
}

enum EventType {
  STATUS_CHANGE
  COMMENT
  PENDENCY_CREATED
  DOCUMENT_ATTACHED
  SYSTEM_LOG
}

model TimelineEvent {
  id         String    @id @default(uuid())
  proposalId String
  userId     String
  eventType  EventType
  content    Json?    
  createdAt  DateTime  @default(now())

  proposal   Proposal  @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id])

  @@map("timeline_events")
}
